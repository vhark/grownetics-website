---
const year = new Date().getFullYear();

const products = [
  { label: 'CropVision', href: '/cropvision' },
  { label: 'Unity Automation', href: '/unity' },
  { label: 'Foundation Design', href: '/foundation' },
  { label: 'Optima Consulting', href: '/consulting' },
  { label: 'Grownetics OS', href: '/os' },
];

const company = [
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
  { label: 'Book a Demo', href: '/contact' },
];
---

<!-- Pre-footer CTA bar -->
<div style="background: #252729; border-top: 1px solid rgba(233,232,238,0.08);">
  <div class="container py-10 flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
    <div>
      <p class="font-display text-xl font-semibold text-parchment/90 mb-1">
        Ready to see what your operation is actually capable of?
      </p>
      <p class="text-sm text-parchment/40">
        Free one-hour discovery call. No pitch deck. Just your operation and ours.
      </p>
    </div>
    <a href="/contact" class="btn btn-primary flex-shrink-0">
      Book a Discovery Call →
    </a>
  </div>
</div>

<footer style="background: #1E1F21;" class="text-parchment/80 pt-12 pb-8">
  <div class="container">

    <!-- Top grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 pb-12 border-b border-parchment/10">

      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <img
          src="/images/logo-white.png"
          alt="Grownetics"
          width="160"
          height="61"
          class="h-9 w-auto mb-4"
          loading="lazy"
        />
        <p class="text-sm text-parchment/50 leading-relaxed max-w-[220px]">
          Full-stack CEA technology for the growers who take yield seriously.
        </p>
        <div class="mt-5 flex items-center gap-2">
          <span class="mono-label text-parchment/30">Boulder, CO</span>
          <span class="text-parchment/20">·</span>
          <span class="mono-label text-parchment/30">Est. 2015</span>
        </div>
      </div>

      <!-- Products -->
      <div>
        <h3 class="font-mono text-xs tracking-widest uppercase text-parchment/40 mb-4">Products</h3>
        <ul class="space-y-2.5">
          {products.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-sm text-parchment/60 hover:text-parchment transition-colors"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="font-mono text-xs tracking-widest uppercase text-parchment/40 mb-4">Company</h3>
        <ul class="space-y-2.5">
          {company.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-sm text-parchment/60 hover:text-parchment transition-colors"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h3 class="font-mono text-xs tracking-widest uppercase text-parchment/40 mb-4">Stay Current</h3>
        <p class="text-xs text-parchment/40 leading-relaxed mb-4">
          No vendor theater. Grower-relevant content: data, techniques, facility case studies, and early access to what we're building.
        </p>
        <form action="https://grownetics.com/forms/newsletter" method="POST" class="space-y-2">
          <input type="hidden" name="form" value="footer-newsletter" />
          <input
            type="email"
            name="email"
            placeholder="Your work email"
            required
            class="w-full px-3 py-2 rounded text-xs font-mono outline-none"
            style="background: rgba(255,255,255,0.05); border: 1px solid rgba(233,232,238,0.12); color: #E9E8EE;"
          />
          <button type="submit" class="btn w-full justify-center text-xs py-2.5" style="background: var(--green); color: #fff;">
            Subscribe →
          </button>
        </form>
        <div class="mt-4">
          <a href="mailto:hello@grownetics.com" class="text-xs text-parchment/40 hover:text-parchment/70 transition-colors">
            hello@grownetics.com
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <div class="flex flex-wrap items-center gap-4">
        <span class="font-mono text-xs text-parchment/25 tracking-widest">
          © {year} Grownetics, Inc.
        </span>
        <span class="text-parchment/15 hidden md:block">·</span>
        <a href="/privacy" class="font-mono text-xs text-parchment/30 hover:text-parchment/60 transition-colors">
          Privacy
        </a>
        <span class="text-parchment/15">·</span>
        <a href="/terms" class="font-mono text-xs text-parchment/30 hover:text-parchment/60 transition-colors">
          Terms
        </a>
      </div>

      <!-- § Catalog reference - Archival DNA -->
      <div class="flex items-center gap-3">
        <div class="w-2 h-2 rounded-full opacity-60" style="background: var(--green)"></div>
        <span class="font-mono text-xs text-parchment/20 tracking-widest uppercase">
          Grownetics Field Catalog · REF-2026-A
        </span>
      </div>
    </div>
  </div>
</footer>
