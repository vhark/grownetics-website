---
const navLinks = [
  { label: 'Monitor', href: '/cropvision', title: 'CropVision - Environmental Monitoring' },
  { label: 'Control', href: '/unity', title: 'Unity - Precision Automation' },
  { label: 'Design', href: '/foundation', title: 'Foundation - Facility Design' },
  { label: 'Consult', href: '/consulting', title: 'Optima - Cultivation Consulting' },
  { label: 'About', href: '/about', title: 'About Grownetics' },
];

const currentPath = Astro.url.pathname;
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  aria-label="Main navigation"
>
  <div class="container">
    <div class="flex items-center justify-between h-16 md:h-18">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 flex-shrink-0" aria-label="Grownetics home">
        <img
          src="/images/logo-dark.png"
          alt="Grownetics"
          width="180"
          height="69"
          class="h-10 w-auto"
          loading="eager"
        />
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            title={link.title}
            class:list={[
              'px-3 py-1.5 rounded font-mono text-xs tracking-widest uppercase transition-colors duration-150',
              'text-ink-3 hover:text-ink hover:bg-black/5',
              currentPath === link.href || currentPath.startsWith(link.href + '/')
                ? 'text-ink font-medium'
                : '',
            ]}
            aria-current={currentPath === link.href ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- CTA + Hamburger -->
      <div class="flex items-center gap-2">
        <a
          href="/contact"
          class="hidden md:inline-flex btn border text-xs py-2 px-4"
          style="border-color: rgba(77,180,5,0.35); color: var(--green);"
        >
          Contact
        </a>
        <a
          href="/os"
          class="hidden md:inline-flex btn btn-primary text-xs py-2.5 px-5"
        >
          Join OS Waitlist ↗
        </a>

        <!-- Mobile hamburger -->
        <button
          id="menu-toggle"
          class="md:hidden flex flex-col gap-1.5 p-2 rounded"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span class="menu-bar block w-5 h-0.5 bg-ink-2 transition-all duration-200"></span>
          <span class="menu-bar block w-5 h-0.5 bg-ink-2 transition-all duration-200"></span>
          <span class="menu-bar block w-5 h-0.5 bg-ink-2 transition-all duration-200"></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-border-light bg-parchment/98 backdrop-blur-sm"
  >
    <div class="container py-4 flex flex-col gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'py-3 px-3 rounded font-mono text-xs tracking-widest uppercase transition-colors',
            'text-ink-3',
            currentPath === link.href ? 'font-medium text-ink' : '',
          ]}
        >
          {link.label}
        </a>
      ))}
      <div class="mt-3 pt-3 border-t border-border-light flex flex-col gap-2">
        <a
          href="/contact"
          class="btn w-full justify-center text-xs py-3"
          style="border: 1.5px solid rgba(77,180,5,0.35); color: var(--green);"
        >
          Contact
        </a>
        <a href="/os" class="btn btn-primary w-full justify-center text-xs py-3">
          Join OS Waitlist ↗
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const open = menu.classList.toggle('hidden');
      toggle.setAttribute('aria-expanded', String(!open));
    });
  }
</script>

<style>
  nav {
    background: transparent;
  }
</style>
