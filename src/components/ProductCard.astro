---
interface Props {
  name: string;
  tagline: string;
  description: string;
  href: string;
  icon?: string;
  badge?: string;
  badgeType?: 'green' | 'gold' | 'terracotta';
  highlight?: boolean;
  stats?: Array<{ value: string; label: string }>;
}

const {
  name,
  tagline,
  description,
  href,
  icon,
  badge,
  badgeType = 'green',
  highlight = false,
  stats = [],
} = Astro.props;
---

<a
  href={href}
  class:list={[
    'card block p-7 group relative overflow-hidden',
    highlight ? 'border-green/30 ring-1 ring-green/20' : '',
  ]}
>
  <!-- Gold top accent if highlight -->
  {highlight && (
    <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-green via-green-light to-transparent"></div>
  )}

  <!-- Header -->
  <div class="flex items-start justify-between mb-4">
    {icon && (
      <div class="text-2xl mr-3 flex-shrink-0">{icon}</div>
    )}
    <div class="flex-1">
      <div class="flex items-center gap-2 mb-1">
        {badge && (
          <span class:list={['badge', `badge-${badgeType}`]}>{badge}</span>
        )}
      </div>
      <h3 class="font-display text-xl font-semibold text-ink group-hover:text-green transition-colors">
        {name}
      </h3>
    </div>
    <span class="text-green/40 group-hover:text-green group-hover:translate-x-1 transition-all duration-200 text-xl flex-shrink-0 ml-2">→</span>
  </div>

  <!-- Tagline -->
  <p class="font-mono text-xs text-gold tracking-widest uppercase mb-3">{tagline}</p>

  <!-- Description -->
  <p class="text-sm text-ink-3 leading-relaxed mb-5">{description}</p>

  <!-- Stats -->
  {stats.length > 0 && (
    <div class="flex gap-6 pt-4 border-t border-border-light">
      {stats.map((stat) => (
        <div>
          <div class="font-display text-xl font-bold text-green">{stat.value}</div>
          <div class="font-mono text-xs text-text-muted uppercase tracking-wide mt-0.5" style="color: var(--text-muted)">{stat.label}</div>
        </div>
      ))}
    </div>
  )}
</a>
