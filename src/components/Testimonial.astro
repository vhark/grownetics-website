---
interface Props {
  quote: string;
  name: string;
  title: string;
  company: string;
  imageSrc?: string;
  metric?: { value: string; label: string };
}

const {
  quote,
  name,
  title,
  company,
  imageSrc,
  metric,
} = Astro.props;
---

<!-- Brand guide blockquote: 30px/30px, border-left 3px, pl 40px -->
<blockquote class="card p-8 flex flex-col gap-6" style="border-left: 3px solid var(--border-light);">
  <!-- Quote mark - Archival DNA retained -->
  <div class="font-display text-5xl font-bold leading-none select-none" style="color: rgba(77,180,5,0.18);" aria-hidden="true">"</div>

  <!-- Quote text - brand guide blockquote style -->
  <p class="font-body text-xl italic text-ink-2 leading-relaxed flex-1">
    {quote}
  </p>

  <!-- Metric highlight if provided -->
  {metric && (
    <div class="flex items-center gap-4 py-4 border-y border-border-light">
      <div class="stat-number text-2xl">{metric.value}</div>
      <div class="font-mono text-xs text-ink-3 uppercase tracking-wide">{metric.label}</div>
    </div>
  )}

  <!-- Attribution -->
  <div class="flex items-center gap-4">
    {imageSrc && (
      <img
        src={imageSrc}
        alt={name}
        width="48"
        height="48"
        class="w-12 h-12 rounded-full object-cover flex-shrink-0 border-2 border-border-light"
        loading="lazy"
      />
    )}
    {!imageSrc && (
      <div
        class="w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0 font-display text-lg font-bold"
        style="background: rgba(77,180,5,0.10); color: var(--green);"
      >
        {name.charAt(0)}
      </div>
    )}
    <div>
      <div class="font-display font-semibold text-ink text-sm">{name}</div>
      <div class="font-mono text-xs text-ink-3 uppercase tracking-wide mt-0.5">{title} · {company}</div>
    </div>
  </div>
</blockquote>
