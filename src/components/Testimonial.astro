---
interface Props {
  quote: string;
  name: string;
  title: string;
  company: string;
  imageSrc?: string;
  metric?: { value: string; label: string };
}

const {
  quote,
  name,
  title,
  company,
  imageSrc,
  metric,
} = Astro.props;
---

<blockquote class="card p-8 flex flex-col gap-6">
  <!-- Quote mark -->
  <div class="font-display text-5xl text-green/20 leading-none select-none" aria-hidden="true">"</div>

  <!-- Quote text -->
  <p class="font-display text-xl italic text-ink-2 leading-relaxed flex-1">
    {quote}
  </p>

  <!-- Metric highlight if provided -->
  {metric && (
    <div class="flex items-center gap-4 py-4 border-y border-border-light">
      <div class="stat-number text-2xl">{metric.value}</div>
      <div class="font-mono text-xs text-ink-3 uppercase tracking-wide">{metric.label}</div>
    </div>
  )}

  <!-- Attribution -->
  <div class="flex items-center gap-4">
    {imageSrc && (
      <img
        src={imageSrc}
        alt={name}
        width="48"
        height="48"
        class="w-12 h-12 rounded-full object-cover flex-shrink-0 border-2 border-border-light"
        loading="lazy"
      />
    )}
    {!imageSrc && (
      <div class="w-12 h-12 rounded-full bg-green/10 flex items-center justify-center flex-shrink-0 text-green font-display text-lg font-semibold">
        {name.charAt(0)}
      </div>
    )}
    <div>
      <div class="font-semibold text-ink text-sm">{name}</div>
      <div class="font-mono text-xs text-ink-3 uppercase tracking-wide mt-0.5">{title} · {company}</div>
    </div>
  </div>
</blockquote>
