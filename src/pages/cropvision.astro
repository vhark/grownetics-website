---
import Base from '../layouts/Base.astro';
import CTASection from '../components/CTASection.astro';
---

<Base
  title="CropVision by Grownetics — Commercial Crop Monitoring & Environmental Intelligence"
  description="10x resolution wireless monitoring for commercial CEA. 3D microclimate mapping, substrate analytics, VPD/DLI/CO2 tracking. Total Crop Steering™ platform. Book a demo."
  canonical="/cropvision"
>

  <!-- ═══════════════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════════════════ -->
  <section class="relative min-h-[65vh] flex items-center graph-grid pt-16" aria-labelledby="cv-headline">
    <div class="absolute inset-0 overflow-hidden">
      <img
        src="/images/platform-mockup.jpg"
        alt=""
        role="presentation"
        class="w-full h-full object-cover opacity-20"
        loading="eager"
        width="1920"
        height="1080"
      />
      <div class="absolute inset-0" style="background: linear-gradient(135deg, var(--bg) 50%, transparent)"></div>
    </div>

    <div class="container relative z-10 py-20">
      <div class="max-w-2xl">

        <div class="section-ref mb-6">
          <div class="section-ref-bar"></div>
          <span class="ref-label">§ 001 · See.</span>
        </div>

        <div class="flex flex-wrap gap-2 mb-6">
          <span class="badge badge-green">Wireless Monitoring</span>
          <span class="badge badge-gold">Open Sensor Ecosystem</span>
        </div>

        <h1 id="cv-headline" class="display-xl mb-5">
          Finally see what your crop<br />
          is actually experiencing.
        </h1>
        <p class="text-xl font-display italic text-ink-2 mb-4">
          Commercial-grade wireless monitoring with 10x the resolution of standard systems.
          3D microclimate mapping. The data you need to make decisions that actually hold.
        </p>
        <p class="text-lg text-ink-3 leading-relaxed mb-8 max-w-xl">
          Most monitoring systems tell you what the air is doing. CropVision tells you
          what the plant is experiencing — at canopy, at substrate, across every zone
          in your facility. That's the difference between data and intelligence.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/contact" class="btn btn-primary">Book a Demo →</a>
          <a href="#features" class="btn btn-ghost">See All Features</a>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       § 001 — THE MONITORING GAP
  ═══════════════════════════════════════════════════════════ -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-ref">
        <div class="section-ref-bar" style="background: var(--terracotta)"></div>
        <span class="ref-label" style="color: var(--terracotta)">§ 001 · The Monitoring Gap</span>
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="reveal">
          <h2 class="display-md mb-6">
            There's a difference between having sensors<br />
            <span style="color: var(--terracotta)">and having visibility.</span>
          </h2>
          <p class="text-ink-3 leading-relaxed mb-4">
            A single temperature sensor in a 4,000 sq ft room is a guess, not a measurement.
            Microclimates are real. VPD at canopy versus substrate can vary by 0.4+ kPa
            in the same room. That variance is your yield variance.
          </p>
          <p class="text-ink-3 leading-relaxed mb-4">
            Most monitoring systems log what happened. CropVision's Total Crop Steering™
            platform tells you what it means — and what to do next. Every data point
            connects to a cultivation decision.
          </p>
          <p class="text-ink-3 leading-relaxed">
            The best sensor networks work with your facility, not against it. CropVision
            integrates with Aranet wireless sensors and your existing hardware — no
            rip-and-replace, no proprietary lock-in.
          </p>
        </div>

        <div class="reveal">
          <img
            src="/images/chart-detail.jpg"
            alt="Analytics dashboard showing microclimate data"
            width="600"
            height="400"
            class="rounded-lg shadow-warm-lg w-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       § 002 — WHAT CROPVISION MONITORS
  ═══════════════════════════════════════════════════════════ -->
  <section class="section" id="features" aria-labelledby="cv-features-headline">
    <div class="container">

      <div class="section-ref">
        <div class="section-ref-bar"></div>
        <span class="ref-label">§ 002 · What CropVision Monitors</span>
      </div>

      <div class="max-w-xl mb-12">
        <h2 id="cv-features-headline" class="display-lg mb-4">
          Every variable that matters.<br />In every zone that matters.
        </h2>
        <p class="text-ink-3 leading-relaxed">
          Every parameter your cultivation team needs to make confident decisions —
          from transplant to harvest.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 reveal">
        {[
          {
            label: "VPD",
            name: "Vapor Pressure Deficit",
            desc: "Zone-level VPD calculated in real time for precise transpiration control across every growth stage.",
            icon: "💧",
          },
          {
            label: "DLI",
            name: "Daily Light Integral",
            desc: "Cumulative light dose tracking to optimize photoperiod scheduling and light intensity decisions.",
            icon: "☀️",
          },
          {
            label: "CO₂",
            name: "Carbon Dioxide",
            desc: "Canopy-level CO₂ concentration mapped in 3D to identify enrichment dead zones before they cost yield.",
            icon: "🌿",
          },
          {
            label: "PAR",
            name: "Photosynthetically Active Radiation",
            desc: "PPFD mapping at canopy level to identify hot spots, shadowing, and fixture efficiency.",
            icon: "🔆",
          },
          {
            label: "EC + VWC",
            name: "Substrate Analytics",
            desc: "Electrical conductivity and volumetric water content for Total Crop Steering™ precision at the root zone.",
            icon: "🌱",
          },
          {
            label: "pH",
            name: "Substrate pH",
            desc: "Real-time pH monitoring at the root zone — catch nutrient lockout before yield loss registers.",
            icon: "⚗️",
          },
        ].map((feature) => (
          <div class="card p-6">
            <div class="text-2xl mb-3">{feature.icon}</div>
            <div class="badge badge-green mb-3">{feature.label}</div>
            <h3 class="font-semibold text-ink mb-2">{feature.name}</h3>
            <p class="text-sm text-ink-3 leading-relaxed">{feature.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       § 003 — VS COMPETITION
  ═══════════════════════════════════════════════════════════ -->
  <section class="section section-surface">
    <div class="container">

      <div class="section-ref">
        <div class="section-ref-bar"></div>
        <span class="ref-label">§ 003 · Why CropVision vs. the Alternatives</span>
      </div>

      <div class="max-w-xl mb-10 reveal">
        <h2 class="display-lg mb-4">
          Argus and Priva give you data.<br />
          <span style="color: var(--green)">CropVision gives you what the data means.</span>
        </h2>
        <p class="text-ink-3 leading-relaxed">
          Sensor lock-in is a business risk. Every year you're locked to a vendor's hardware
          roadmap, you're dependent on their upgrade cycle. CropVision was built to work
          with the best sensors available — today and five years from now.
        </p>
      </div>

      <div class="card overflow-hidden reveal">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr style="background: var(--surface-2); border-bottom: 1px solid var(--border-light)">
                <th class="text-left p-4 font-mono text-xs text-ink-3 uppercase tracking-widest">What you need</th>
                <th class="text-left p-4 font-mono text-xs text-ink-3 uppercase tracking-widest">Legacy systems</th>
                <th class="text-left p-4 font-mono text-xs font-medium uppercase tracking-widest" style="color: var(--green)">CropVision</th>
              </tr>
            </thead>
            <tbody>
              {[
                { need: "Zone-level resolution", legacy: "Single-point readings", cv: "3D microclimate mapping" },
                { need: "Substrate intelligence", legacy: "Air measurements only", cv: "EC, VWC, pH at the root zone" },
                { need: "Actionable guidance", legacy: "Raw charts", cv: "Total Crop Steering™ framework" },
                { need: "Hardware flexibility", legacy: "Proprietary sensor lock-in", cv: "Open ecosystem (Aranet + existing hardware)" },
                { need: "Cost of implementation", legacy: "$$$$ enterprise contracts", cv: "~60% less than comparable Argus/Priva" },
              ].map((row, i) => (
                <tr style={i % 2 === 0 ? 'background: var(--surface)' : 'background: var(--surface-2)'}>
                  <td class="p-4 font-medium text-ink">{row.need}</td>
                  <td class="p-4 text-ink-3">{row.legacy}</td>
                  <td class="p-4 font-medium" style="color: var(--green)">{row.cv}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       § 004 — TOTAL CROP STEERING™
  ═══════════════════════════════════════════════════════════ -->
  <section class="section">
    <div class="container">

      <div class="section-ref">
        <div class="section-ref-bar" style="background: var(--gold)"></div>
        <span class="ref-label">§ 004 · Proprietary IP</span>
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="reveal">
          <img
            src="/images/flower-detail.jpg"
            alt="Cannabis flower detail showing precision cultivation"
            width="600"
            height="500"
            class="rounded-lg shadow-warm-lg w-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="reveal">
          <span class="badge badge-gold mb-4">Proprietary Framework</span>
          <h2 class="display-md mb-4">Total Crop Steering™</h2>
          <p class="text-ink-3 leading-relaxed mb-5">
            The Total Crop Steering™ platform translates your environmental data into
            cultivation guidance — connecting measurements to the specific decisions
            your team faces at each growth stage. It's the methodology that makes
            the data actionable.
          </p>
          <p class="text-ink-3 leading-relaxed mb-6">
            Not a generic protocol. A data-driven methodology developed and refined
            across 1M+ square feet of commercial production.
          </p>
          <ul class="space-y-3">
            {[
              "Stage-by-stage substrate targets, not one-size-fits-all recipes",
              "Integrates with Unity automation for closed-loop control",
              "Exportable to any cultivation consultant or compliance audit",
              "University of Colorado affiliated validation studies",
            ].map((point) => (
              <li class="feature-check">
                <div class="check-icon">
                  <svg width="10" height="8" viewBox="0 0 10 8" fill="none">
                    <path d="M1 4l3 3 5-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <span class="text-sm text-ink-3">{point}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       § 005 — DEPLOYED AT SCALE
  ═══════════════════════════════════════════════════════════ -->
  <section class="section section-alt">
    <div class="container">

      <div class="section-ref">
        <div class="section-ref-bar" style="background: var(--green)"></div>
        <span class="ref-label">§ 005 · Deployed in Commercial Facilities</span>
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="reveal">
          <h2 class="display-md mb-5">
            Proven across 1M+ square feet<br />
            <span style="color: var(--green)">of commercial CEA.</span>
          </h2>
          <p class="text-ink-3 leading-relaxed mb-6">
            Deployed across cannabis, produce, and specialty crops in Colorado,
            California, Canada, and internationally.
          </p>

          <blockquote class="card p-6" style="border-left: 3px solid var(--green)">
            <p class="font-display italic text-ink-2 mb-4 text-base leading-relaxed">
              "We had sensors before CropVision. We had data. What we didn't have was
              visibility — I couldn't tell you what was happening in the southeast corner
              of Room 2 versus the northwest. Now I can. And it changed how we manage
              every room."
            </p>
            <div class="font-mono text-xs text-ink-3 uppercase tracking-widest">
              Head Grower — 40,000 sq ft facility, CA
            </div>
          </blockquote>
        </div>

        <div class="reveal">
          <div class="grid grid-cols-2 gap-4">
            {[
              { name: "The Work", location: "Colorado" },
              { name: "House of Cultivars", location: "Colorado" },
              { name: "Green Horizons", location: "California" },
              { name: "Fields of Light", location: "Canada" },
            ].map((c) => (
              <div class="card p-4 text-center">
                <div class="font-display font-semibold text-ink mb-1">{c.name}</div>
                <div class="font-mono text-xs text-gold uppercase tracking-widest">{c.location}</div>
              </div>
            ))}
          </div>

          <div class="mt-6 grid grid-cols-3 gap-4">
            {[
              { value: "1M+", label: "sq ft deployed" },
              { value: "10x", label: "Resolution vs standard" },
              { value: "60%", label: "Less than Argus/Priva" },
            ].map((stat) => (
              <div class="card p-4 text-center">
                <div class="stat-number text-xl mb-1">{stat.value}</div>
                <div class="font-mono text-xs text-ink-3 leading-snug uppercase tracking-wide">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>


  <CTASection
    sectionRef="006"
    eyebrow="Book a Demo"
    headline="See your operation with 10x the resolution you have today."
    body="Book a demo. We'll walk through CropVision in a facility similar to yours — and show you exactly what you're not seeing."
    cta={{ label: "Book a Demo →", href: "/contact" }}
    ctaSecondary={{ label: "Talk to a Grower on Our Team", href: "/contact" }}
    variant="dark"
  />

</Base>
