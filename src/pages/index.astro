---
import Base from '../layouts/Base.astro';
import ProductCard from '../components/ProductCard.astro';
import Testimonial from '../components/Testimonial.astro';
import CTASection from '../components/CTASection.astro';
---

<Base
  title="Grownetics — See. Control. Optimize."
  description="Full-stack CEA technology for commercial cannabis and controlled environment agriculture. Wireless monitoring, intelligent automation, precision facility design, and AI operations."
  canonical="/"
>

  <!-- ═══════════════════════════════════════════════════════
       HERO — See. Control. Optimize.
  ═══════════════════════════════════════════════════════════ -->
  <section class="relative min-h-screen flex items-center graph-grid pt-16" aria-labelledby="hero-headline">
    <!-- Background image with warm overlay -->
    <div class="absolute inset-0 overflow-hidden">
      <img
        src="/images/hero-bg.jpg"
        alt=""
        role="presentation"
        class="w-full h-full object-cover"
        loading="eager"
        width="1920"
        height="1080"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-parchment via-parchment/90 to-parchment/20"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-parchment/60 via-transparent to-transparent"></div>
    </div>

    <div class="container relative z-10 py-24">
      <div class="max-w-2xl">

        <!-- Section ref -->
        <div class="section-ref mb-8">
          <div class="section-ref-bar"></div>
          <span class="ref-label">§ 001 · Field Operations</span>
        </div>

        <!-- Eyebrow badges -->
        <div class="flex flex-wrap gap-2 mb-6">
          <span class="badge badge-green">1M+ sqft managed</span>
          <span class="badge badge-gold">60+ years combined expertise</span>
        </div>

        <!-- Main headline -->
        <h1 id="hero-headline" class="display-xl mb-6">
          See. Control.<br />
          <span style="color: var(--green)">Optimize.</span>
        </h1>

        <p class="text-xl font-display text-ink-2 italic mb-4">
          Your facility underperforms because it can't see itself clearly.
        </p>

        <p class="text-lg text-ink-3 leading-relaxed mb-10 max-w-xl">
          Grownetics delivers full-stack CEA technology — from wireless microclimate
          sensors to intelligent automation to AI-powered operations. Built by growers,
          for growers who take yield seriously.
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="/contact" class="btn btn-primary">
            Book a Free Discovery Call
            <span aria-hidden="true">→</span>
          </a>
          <a href="/cropvision" class="btn btn-ghost">
            Explore CropVision
          </a>
        </div>

        <!-- Trust signals -->
        <div class="mt-12 flex flex-wrap items-center gap-6">
          <div class="flex items-center gap-2">
            <div class="w-2 h-2 rounded-full bg-green"></div>
            <span class="font-mono text-xs text-ink-3 uppercase tracking-widest">UL Certified</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-2 h-2 rounded-full bg-green"></div>
            <span class="font-mono text-xs text-ink-3 uppercase tracking-widest">CO / CA / Canada</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-2 h-2 rounded-full bg-green"></div>
            <span class="font-mono text-xs text-ink-3 uppercase tracking-widest">University of Colorado Studies</span>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       § 002 — THE PROBLEM
  ═══════════════════════════════════════════════════════════ -->
  <section class="section section-alt" aria-labelledby="problem-headline">
    <div class="container">

      <div class="section-ref">
        <div class="section-ref-bar" style="background: var(--terracotta)"></div>
        <span class="ref-label" style="color: var(--terracotta)">§ 002 · Field Observation</span>
      </div>

      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="reveal">
          <h2 id="problem-headline" class="display-lg mb-6">
            The grower isn't broken.<br />
            <span style="color: var(--terracotta)">The system is.</span>
          </h2>
          <p class="text-lg text-ink-3 leading-relaxed mb-6">
            Commercial grows are flying blind. Temperature sensors in the wrong corners.
            Climate control reacting instead of predicting. Facility designs that lock you
            into vendor dependency before you've even planted.
          </p>
          <p class="text-ink-3 leading-relaxed">
            The result? Inconsistent yields, runaway energy bills, and harvest data that
            tells you what happened — never what to do next. As markets mature, inefficient
            grows don't survive. Precision isn't a luxury. It's table stakes.
          </p>
        </div>

        <div class="reveal grid grid-cols-2 gap-4">
          {[
            { problem: "Climate blind spots", impact: "Uneven canopy development, hot/cold zones destroying consistency" },
            { problem: "Reactive controls", impact: "Energy waste from thermostat logic that can't anticipate VPD swings" },
            { problem: "Vendor lock-in", impact: "Proprietary hardware that doubles your cost and halves your control" },
            { problem: "Tribal knowledge", impact: "Expert know-how that leaves with your head grower" },
          ].map((item) => (
            <div class="card p-5" style="border-left: 3px solid var(--terracotta)">
              <h3 class="font-semibold text-sm text-ink mb-2">{item.problem}</h3>
              <p class="text-xs text-ink-3 leading-relaxed">{item.impact}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       § 003 — PRODUCT STACK
  ═══════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="products-headline">
    <div class="container">

      <div class="section-ref">
        <div class="section-ref-bar"></div>
        <span class="ref-label">§ 003 · The Stack</span>
      </div>

      <div class="max-w-xl mb-12">
        <h2 id="products-headline" class="display-lg mb-4">
          The complete operating picture.
        </h2>
        <p class="text-lg text-ink-3 leading-relaxed">
          Four integrated capabilities — or use any one standalone. Each layer feeds
          the next. Together, they close the loop from observation to optimization.
        </p>
      </div>

      <!-- Product grid -->
      <div class="grid sm:grid-cols-2 gap-5 reveal">
        <ProductCard
          name="CropVision"
          tagline="See with precision"
          description="Wireless 3D microclimate mapping with substrate-level monitoring. VPD, DLI, CO2, PAR, EC, VWC, and pH — in real time, without hardware lock-in."
          href="/cropvision"
          badge="Monitoring"
          badgeType="green"
          stats={[
            { value: "60%", label: "Cost vs. Argus/Priva" },
            { value: "3D", label: "Microclimate mapping" },
          ]}
        />
        <ProductCard
          name="Unity"
          tagline="Control with intelligence"
          description="Predictive climate and CO2 automation with hybrid lighting integration. UL-certified controls engineered for total redundancy and 40% cost reduction."
          href="/unity"
          badge="Automation"
          badgeType="gold"
          stats={[
            { value: "40%", label: "Cost reduction" },
            { value: "20%", label: "Energy savings" },
          ]}
        />
        <ProductCard
          name="Foundation"
          tagline="Design for efficiency"
          description="Smart facility design from greenfield to retrofit. Four pillars: Hyper Efficient, Bio-Secure, Compliant, Precise. CAD engineering built around your operation."
          href="/foundation"
          badge="Facility Design"
          badgeType="terracotta"
        />
        <ProductCard
          name="Optima Consulting"
          tagline="Optimize continuously"
          description="Site evaluations, supplier audits, and cultivation support from experts who've managed over a million square feet across CO, CA, and Canada."
          href="/consulting"
          badge="Consulting"
          badgeType="gold"
          stats={[
            { value: "2.5–3.2", label: "lbs per light" },
          ]}
        />
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       § 004 — GROWNETICS OS TEASER
  ═══════════════════════════════════════════════════════════ -->
  <section class="section bg-ink relative overflow-hidden" aria-labelledby="os-headline">
    <!-- Dark background with subtle grain & grid -->
    <div class="absolute inset-0 graph-grid opacity-10"></div>
    <div class="absolute bottom-0 left-0 w-2/3 h-96 opacity-20"
         style="background: radial-gradient(ellipse at bottom left, var(--green) 0%, transparent 70%)"></div>

    <div class="container relative z-10">

      <div class="flex items-center gap-3 mb-10">
        <div class="w-0.5 h-3.5 rounded bg-gold/60"></div>
        <span class="font-mono text-xs tracking-widest uppercase text-gold/60">§ 004 · Coming Soon</span>
      </div>

      <div class="max-w-3xl">
        <div class="flex flex-wrap gap-3 mb-6">
          <span class="badge" style="color: var(--green-muted); border-color: var(--green-muted); background: rgba(78, 158, 106, 0.1)">
            ◉ In Development
          </span>
          <span class="badge text-parchment/40 border-parchment/20">
            Early Access Opening
          </span>
        </div>

        <h2 id="os-headline" class="font-display text-white" style="font-size: clamp(2.2rem, 4.5vw, 3.5rem); font-weight: 700; line-height: 1.15; margin-bottom: 1.5rem;">
          Grownetics OS.<br />
          <span style="color: var(--green-muted)">The AI layer that connects it all.</span>
        </h2>

        <p class="text-lg leading-relaxed mb-10" style="color: rgba(232, 221, 208, 0.65); max-width: 56ch;">
          Everything you've learned about your facility — every VPD curve, every yield
          deviation, every control decision — becomes searchable, predictive intelligence.
          The operating system for the grower who refuses to leave yield on the table.
        </p>

        <a href="/os" class="btn btn-primary">
          Join the Waitlist
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       § 005 — CREDENTIALS
  ═══════════════════════════════════════════════════════════ -->
  <section class="section section-surface" aria-label="Credentials and track record">
    <div class="container">

      <div class="section-ref">
        <div class="section-ref-bar"></div>
        <span class="ref-label">§ 005 · Track Record</span>
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="reveal">
          <h2 class="display-lg mb-6">
            Built in the grow room.<br />
            Proven in the field.
          </h2>
          <p class="text-ink-3 leading-relaxed mb-6">
            Grownetics was built by operators who've managed commercial grows from
            the ground up. Not consultants who theorize. Engineers and cultivators
            who've debugged VPD at 2am and redesigned climate logic mid-cycle.
          </p>
          <p class="text-ink-3 leading-relaxed">
            Our clients range from boutique craft operators to multi-site MSOs.
            Same platform, same precision, same results.
          </p>
        </div>

        <!-- Stats grid -->
        <div class="reveal grid grid-cols-2 gap-6">
          {[
            { value: "1M+", label: "Square feet managed", detail: "CO · CA · Canada · International" },
            { value: "60+", label: "Years combined expertise", detail: "Engineers, cultivators, systems architects" },
            { value: "40%", label: "Avg. cost reduction", detail: "vs. legacy hardware + software" },
            { value: "100%", label: "UL Certified controls", detail: "Total redundancy, zero compromises" },
          ].map((stat) => (
            <div class="card p-6">
              <div class="stat-number mb-1">{stat.value}</div>
              <div class="font-semibold text-sm text-ink mb-1">{stat.label}</div>
              <div class="font-mono text-xs text-ink-3 uppercase tracking-wide leading-snug">{stat.detail}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Client logos row -->
      <div class="mt-16 pt-12 border-t border-border-light">
        <p class="font-mono text-xs text-ink-3 uppercase tracking-widest mb-8 text-center">
          Trusted by leading cultivators
        </p>
        <div class="flex flex-wrap justify-center items-center gap-8 md:gap-14 opacity-60">
          {[
            'The Work', 'House of Cultivars', 'Green Horizons', 'Fields of Light'
          ].map((client) => (
            <span class="font-display text-lg font-semibold text-ink-3 italic">{client}</span>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       § 006 — TESTIMONIALS
  ═══════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="testimonials-headline">
    <div class="container">

      <div class="section-ref">
        <div class="section-ref-bar"></div>
        <span class="ref-label">§ 006 · Field Reports</span>
      </div>

      <h2 id="testimonials-headline" class="display-md mb-12 max-w-lg">
        What growers say after they can finally see.
      </h2>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 reveal">
        <Testimonial
          quote="We cut our power bill by nearly 20% in the first quarter and our yields went up 18%. CropVision showed us exactly where we were wasting energy."
          name="Cody M."
          title="Head Grower"
          company="House of Cultivars"
          imageSrc="/images/testimonial-cody.jpg"
          metric={{ value: "18%", label: "Yield increase in Q1" }}
        />
        <Testimonial
          quote="The Unity system paid for itself in four months. Before Grownetics, we were running four separate systems that didn't talk to each other. Now everything is one integrated loop."
          name="Director of Operations"
          title="Director of Operations"
          company="The Work"
        />
        <Testimonial
          quote="Their facility design team caught three critical airflow problems before we broke ground. That kind of foresight doesn't come from a vendor who's never been in a grow room."
          name="Facility Manager"
          title="Facility Manager"
          company="Green Horizons"
        />
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       § 007 — FINAL CTA
  ═══════════════════════════════════════════════════════════ -->
  <CTASection
    ref="007"
    eyebrow="Discovery Call"
    headline="One hour. Free. No pitch deck."
    body="We'll look at your facility data, identify your top three constraints, and show you what the Grownetics stack can actually do for your operation."
    cta={{ label: "Book Your Discovery Call", href: "/contact" }}
    ctaSecondary={{ label: "Explore the Platform", href: "/cropvision" }}
    variant="dark"
  />

</Base>
