---
import Base from '../layouts/Base.astro';
import ProductCard from '../components/ProductCard.astro';
import Testimonial from '../components/Testimonial.astro';
import CTASection from '../components/CTASection.astro';
---

<Base
  title="Grownetics — See. Control. Optimize. | CEA Technology Stack"
  description="Complete CEA technology for commercial cultivation — wireless monitoring, precision automation, facility design, and consulting. 1M+ sq ft deployed. Book a discovery call."
  canonical="/"
>

  <!-- ═══════════════════════════════════════════════════════
       HERO — See. Control. Optimize.
  ═══════════════════════════════════════════════════════════ -->
  <section class="relative min-h-screen flex items-center graph-grid pt-16" aria-labelledby="hero-headline">
    <div class="absolute inset-0 overflow-hidden">
      <img
        src="/images/hero-bg.jpg"
        alt=""
        role="presentation"
        class="w-full h-full object-cover"
        loading="eager"
        width="1920"
        height="1080"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-parchment via-parchment/90 to-parchment/20"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-parchment/60 via-transparent to-transparent"></div>
    </div>

    <div class="container relative z-10 py-28">
      <div class="max-w-2xl">

        <div class="section-ref mb-8">
          <div class="section-ref-bar"></div>
          <span class="ref-label">§ 001 · Field Operations</span>
        </div>

        <h1 id="hero-headline" class="display-xl mb-6">
          See. Control.<br />
          <span style="color: var(--green)">Optimize.</span>
        </h1>

        <p class="text-xl font-display italic text-ink-2 mb-3">
          The complete technology stack for commercial cultivation — from sensor to decision.
        </p>

        <p class="text-lg text-ink-3 leading-relaxed mb-10 max-w-xl">
          Most CEA technology was built to watch your grow. Grownetics was built to run it.
          High-resolution monitoring, precision automation, facility design, and expert
          consulting — fully integrated, commercially proven, designed for operators who
          can't afford to guess.
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="/cropvision" class="btn btn-primary">Explore the Stack →</a>
          <a href="/contact" class="btn btn-ghost">Book a Discovery Call</a>
        </div>

        <div class="mt-12 flex flex-wrap items-center gap-6">
          <div class="flex items-center gap-2">
            <div class="w-2 h-2 rounded-full" style="background: var(--green)"></div>
            <span class="font-mono text-xs text-ink-3 uppercase tracking-widest">UL Certified</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-2 h-2 rounded-full" style="background: var(--green)"></div>
            <span class="font-mono text-xs text-ink-3 uppercase tracking-widest">1M+ sq ft deployed</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-2 h-2 rounded-full" style="background: var(--green)"></div>
            <span class="font-mono text-xs text-ink-3 uppercase tracking-widest">CO · CA · Canada · International</span>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       § 001 — THE PROBLEM
  ═══════════════════════════════════════════════════════════ -->
  <section class="section section-alt" aria-labelledby="problem-headline">
    <div class="container">

      <div class="section-ref">
        <div class="section-ref-bar" style="background: var(--terracotta)"></div>
        <span class="ref-label" style="color: var(--terracotta)">§ 001 · The Real Cost of Fragmented Systems</span>
      </div>

      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="reveal">
          <h2 id="problem-headline" class="display-lg mb-4">
            Your growers aren't the problem.<br />
            <span style="color: var(--terracotta)">Your tools are.</span>
          </h2>
          <p class="text-lg text-ink-3 leading-relaxed mb-4">
            Commercial cultivation is one of the most demanding environments in agriculture.
            The technology most operations run on wasn't built for it.
          </p>
          <p class="text-ink-3 leading-relaxed">
            The grower isn't broken. The system is. And fixing it doesn't start with another
            tool — it starts with a complete one.
          </p>
        </div>

        <div class="reveal grid grid-cols-1 gap-4">
          <div class="card p-6" style="border-left: 3px solid var(--terracotta)">
            <h3 class="font-display font-semibold text-sm text-ink mb-2">Blind Spots</h3>
            <p class="text-xs text-ink-3 leading-relaxed">
              You have sensors. But do you have a 3D picture of every zone? Temperature at canopy isn't temperature at substrate. The gap between your readings and reality is costing you yield.
            </p>
          </div>
          <div class="card p-6" style="border-left: 3px solid var(--terracotta)">
            <h3 class="font-display font-semibold text-sm text-ink mb-2">Reactive Control</h3>
            <p class="text-xs text-ink-3 leading-relaxed">
              If your climate control is reacting to problems, it's already too late. By the time a thermostat catches a VPD excursion, your plants have been stressed for hours. Every reaction is a recovery.
            </p>
          </div>
          <div class="card p-6" style="border-left: 3px solid var(--terracotta)">
            <h3 class="font-display font-semibold text-sm text-ink mb-2">Institutional Knowledge</h3>
            <p class="text-xs text-ink-3 leading-relaxed">
              Your best grower knows things your systems don't. When they leave, that knowledge goes with them. The operation runs on tribal wisdom instead of documented precision.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       § 002 — THE STACK
  ═══════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="stack-headline">
    <div class="container">

      <div class="section-ref">
        <div class="section-ref-bar"></div>
        <span class="ref-label">§ 002 · The Grownetics Stack</span>
      </div>

      <div class="max-w-xl mb-12">
        <h2 id="stack-headline" class="display-lg mb-4">
          Four layers. One coherent system.
        </h2>
        <p class="text-lg text-ink-3 leading-relaxed">
          Built to work independently or together. Designed so every layer makes
          the next one more powerful.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 gap-5 reveal">
        <ProductCard
          name="CropVision"
          tagline="See."
          description="10x resolution environmental monitoring. 3D microclimate mapping. Total Crop Steering™ analytics. Your operation, finally visible."
          href="/cropvision"
          badge="Monitor"
          badgeType="green"
          stats={[
            { value: "60%", label: "Less than Argus/Priva" },
            { value: "10x", label: "Sensor resolution" },
          ]}
        />
        <ProductCard
          name="Unity"
          tagline="Control."
          description="Predictive climate, CO₂, and lighting automation. UL-certified. 20% average energy savings. Precision that compounds over time."
          href="/unity"
          badge="Automate"
          badgeType="gold"
          stats={[
            { value: "20%", label: "Avg. energy savings" },
            { value: "40%", label: "Cost reduction" },
          ]}
        />
        <ProductCard
          name="Foundation"
          tagline="Design."
          description="From greenfield to retrofit — facility design engineered for efficiency, bio-security, compliance, and precision from day one."
          href="/foundation"
          badge="Design"
          badgeType="terracotta"
        />
        <ProductCard
          name="Optima Consulting"
          tagline="Optimize."
          description="Site evaluations, cultivation support, supplier audits. Expert growers who've run commercial facilities — not consultants who've read about them."
          href="/consulting"
          badge="Consult"
          badgeType="gold"
          stats={[
            { value: "2.5–3.2", label: "lbs per light" },
          ]}
        />
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       § 003 — GROWNETICS OS TEASER
  ═══════════════════════════════════════════════════════════ -->
  <section
    class="relative overflow-hidden"
    style="padding: 96px 0; background: #2B2C2E;"
    aria-labelledby="os-teaser-headline"
  >
    <div
      class="absolute inset-0"
      style="background-image: linear-gradient(rgba(154,136,96,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(154,136,96,0.04) 1px, transparent 1px); background-size: 72px 72px;"
    ></div>
    <div
      class="absolute bottom-0 left-0 w-2/3 h-80 pointer-events-none"
      style="background: radial-gradient(ellipse at bottom left, rgba(77,180,5,0.10) 0%, transparent 70%);"
    ></div>

    <div class="container relative z-10">

      <div class="flex items-center gap-3 mb-8">
        <div class="w-0.5 h-3.5 rounded" style="background: rgba(154,136,96,0.5)"></div>
        <span class="font-mono text-xs tracking-widest uppercase" style="color: rgba(154,136,96,0.55)">§ 003 · What's Coming</span>
      </div>

      <div class="max-w-3xl">
        <div class="flex flex-wrap gap-3 mb-6">
          <span
            class="font-mono text-xs tracking-widest uppercase px-3 py-1.5 rounded border"
            style="color: rgba(77,180,5,0.85); border-color: rgba(77,180,5,0.25); background: rgba(77,180,5,0.07);"
          >
            ◉ In Development
          </span>
        </div>

        <h2
          id="os-teaser-headline"
          class="font-display font-semibold mb-5"
          style="font-size: clamp(2rem, 4.5vw, 3.25rem); color: #E9E8EE; line-height: 1.15;"
        >
          Grownetics OS is the AI layer<br />
          <span style="color: #4DB405;">that connects it all.</span>
        </h2>

        <p
          class="text-base leading-relaxed mb-8 max-w-2xl"
          style="color: rgba(151,153,166,0.9); font-size: 1.05rem;"
        >
          Every data point your stack collects. Every decision your team makes.
          One intelligence layer that coordinates them — and gets smarter with every grow.
        </p>

        <a href="/os" class="btn btn-primary">
          Join the Waitlist — Be First →
        </a>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       § 004 — CREDENTIALS
  ═══════════════════════════════════════════════════════════ -->
  <section class="section section-surface" aria-label="Proven at commercial scale">
    <div class="container">

      <div class="section-ref">
        <div class="section-ref-bar"></div>
        <span class="ref-label">§ 004 · Proven at Commercial Scale</span>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16 reveal">
        {[
          { value: "1M+", label: "sq ft managed", detail: "CO · CA · Canada · International" },
          { value: "60+", label: "Years combined experience", detail: "Engineering + cultivation expertise" },
          { value: "UL", label: "Certified controls", detail: "Industrial-grade reliability" },
          { value: "UC", label: "Research affiliated", detail: "University of Colorado studies" },
        ].map((stat) => (
          <div class="card p-5 text-center">
            <div class="stat-number text-2xl mb-1">{stat.value}</div>
            <div class="font-display font-semibold text-sm text-ink mb-1">{stat.label}</div>
            <div class="font-mono text-xs text-ink-3 leading-snug">{stat.detail}</div>
          </div>
        ))}
      </div>

      <div class="flex flex-col items-center">
        <p class="font-mono text-xs text-ink-3 uppercase tracking-widest mb-8">
          Deployed in commercial facilities
        </p>
        <div class="flex flex-wrap justify-center items-center gap-8 md:gap-14 opacity-55">
          {['The Work', 'House of Cultivars', 'Green Horizons', 'Fields of Light'].map((client) => (
            <span class="font-display text-lg font-semibold text-ink-3 italic">{client}</span>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       § 005 — TESTIMONIALS
  ═══════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="testimonials-headline">
    <div class="container">

      <div class="section-ref">
        <div class="section-ref-bar"></div>
        <span class="ref-label">§ 005 · From the Grow Room</span>
      </div>

      <h2 id="testimonials-headline" class="display-md mb-12 max-w-lg reveal">
        What growers say after they can finally see.
      </h2>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 reveal">
        <Testimonial
          quote="Before Grownetics, I was flying blind between my sensors and my controllers. Now I can see exactly what's happening in every zone and my climate responds before the plant feels it. That's not an upgrade. That's a different operation."
          name="Head Grower"
          title="Head Grower"
          company="Commercial Facility, Colorado"
          imageSrc="/images/testimonial-cody.jpg"
        />
        <Testimonial
          quote="We cut our power bill by nearly 20% in the first quarter and our yields went up 18%. CropVision showed us exactly where we were wasting energy — we thought it was the lights. It wasn't."
          name="Cody M."
          title="Operations Lead"
          company="House of Cultivars"
          metric={{ value: "18%", label: "Yield increase Q1" }}
        />
        <Testimonial
          quote="Unity paid for itself in four months. Before, we were running four separate systems that didn't talk to each other. Now everything is one integrated loop. The consistency speaks for itself."
          name="Director of Operations"
          title="Director of Operations"
          company="The Work"
        />
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       § 006 — FINAL CTA
  ═══════════════════════════════════════════════════════════ -->
  <section
    class="section relative overflow-hidden"
    style="background: #2B2C2E;"
    aria-labelledby="final-cta-headline"
  >
    <div
      class="absolute inset-0"
      style="background-image: linear-gradient(rgba(154,136,96,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(154,136,96,0.03) 1px, transparent 1px); background-size: 72px 72px;"
    ></div>

    <div class="container relative z-10 text-center max-w-2xl mx-auto">
      <div class="flex items-center justify-center gap-3 mb-8">
        <div class="h-px w-12" style="background: linear-gradient(to right, transparent, rgba(154,136,96,0.4))"></div>
        <span class="font-mono text-xs tracking-widest uppercase" style="color: rgba(154,136,96,0.55)">§ 006 · Start Here</span>
        <div class="h-px w-12" style="background: linear-gradient(to left, transparent, rgba(154,136,96,0.4))"></div>
      </div>

      <h2
        id="final-cta-headline"
        class="font-display font-bold mb-5"
        style="font-size: clamp(2rem, 4.5vw, 3rem); color: #E9E8EE; line-height: 1.15;"
      >
        Your operation can perform better<br />than it does today.
      </h2>
      <p class="text-base mb-10" style="color: rgba(151,153,166,0.85); max-width: 46ch; margin-inline: auto; line-height: 1.65;">
        Start with a free one-hour discovery call. No pitch deck. Just your operation and ours.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/contact" class="btn btn-primary">Book a Discovery Call →</a>
        <a
          href="/cropvision"
          class="btn"
          style="border: 1px solid rgba(255,255,255,0.2); color: rgba(233,232,238,0.65);"
        >
          Explore the Stack
        </a>
      </div>
    </div>
  </section>

</Base>
