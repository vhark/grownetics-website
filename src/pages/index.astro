---
import Base from '../layouts/Base.astro';
import ProductCard from '../components/ProductCard.astro';
import Testimonial from '../components/Testimonial.astro';
---

<Base
  title="Grownetics | See. Control. Optimize. | CEA Technology Stack"
  description="Complete CEA technology for commercial cultivation: wireless monitoring, precision automation, facility design, and consulting. 1M+ sq ft deployed. Book a discovery call."
  canonical="/"
>

  <!-- ═══════════════════════════════════════════════════════
       HERO — Agricultural imagery + dark energy + stat bar
       FROM: staging1 (greenhouse bg, logo, feel)
       FROM: staging (dark overlay, graph grid, stat bar)
  ═══════════════════════════════════════════════════════════ -->
  <section class="relative min-h-screen flex items-center pt-16" aria-labelledby="hero-headline">

    <!-- Greenhouse / facility photo background -->
    <div class="absolute inset-0 overflow-hidden">
      <img
        src="/images/hero-bg.jpg"
        alt=""
        role="presentation"
        class="w-full h-full object-cover object-center"
        loading="eager"
        width="1920"
        height="1080"
      />
      <!-- Dark overlay with green tint — not pure parchment, keeps agricultural feel -->
      <div class="absolute inset-0" style="background: linear-gradient(105deg, rgba(13,26,13,0.88) 0%, rgba(13,26,13,0.75) 45%, rgba(13,26,13,0.4) 100%);"></div>
      <!-- Graph grid on top -->
      <div class="absolute inset-0" style="background-image: linear-gradient(rgba(82,230,25,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(82,230,25,0.03) 1px, transparent 1px); background-size: 72px 72px;"></div>
      <!-- Phosphor glow — bottom left -->
      <div class="absolute bottom-0 left-0 w-3/4 h-2/3 pointer-events-none" style="background: radial-gradient(ellipse at bottom left, rgba(77,180,5,0.12) 0%, transparent 65%);"></div>
    </div>

    <div class="container relative z-10 py-28">
      <div class="max-w-2xl">

        <div class="section-ref mb-8" style="--ref-bar-color: rgba(82,230,25,0.6);">
          <div class="section-ref-bar" style="background: rgba(82,230,25,0.6);"></div>
          <span class="ref-label" style="color: rgba(82,230,25,0.7);">§ 001 · Field Operations</span>
          <div class="flex-1 h-px" style="background: linear-gradient(to right, rgba(82,230,25,0.15), transparent);"></div>
        </div>

        <h1 id="hero-headline" class="font-display font-bold mb-6 leading-tight" style="font-size: clamp(3rem, 7vw, 5.5rem); color: #E8DDD0; letter-spacing: -0.025em; line-height: 1.05;">
          See. Control.<br />
          <span style="color: #4DB405;">Optimize.</span>
        </h1>

        <p class="text-lg leading-relaxed mb-3 max-w-xl" style="color: rgba(196,217,200,0.7); font-style: italic; font-family: var(--font-display);">
          The complete technology stack for commercial cultivation, from sensor to decision.
        </p>

        <p class="text-base leading-relaxed mb-10 max-w-xl" style="color: rgba(196,217,200,0.55);">
          Most facilities run on two sensor readings a day, reactive controls, and one grower's intuition. Grownetics replaces all three.
        </p>

        <div class="flex flex-wrap gap-4 mb-14">
          <a href="/cropvision" class="btn btn-primary">Explore the Stack →</a>
          <a href="/contact" class="btn" style="border: 1.5px solid rgba(196,217,200,0.3); color: rgba(196,217,200,0.75);">Book a Discovery Call</a>
        </div>

        <!-- Stat bar — inside hero, FROM staging.grownetics.com -->
        <div class="flex flex-wrap items-stretch gap-0 rounded-lg overflow-hidden" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.10); width: fit-content; max-width: 100%;">
          {[
            { num: "1M+",  label: "Sq ft managed" },
            { num: "40%",  label: "Energy reduction" },
            { num: "20%+", label: "HVAC efficiency gain" },
            { num: "2015", label: "Founded in CO" },
          ].map((s, i) => (
            <div class="px-6 py-4 text-center" style={i > 0 ? "border-left: 1px solid rgba(255,255,255,0.08);" : ""}>
              <div class="font-display font-bold leading-none mb-1" style="font-size: 1.5rem; color: #4DB405; letter-spacing: -0.025em;">{s.num}</div>
              <div class="font-mono text-xs uppercase tracking-wider" style="color: rgba(196,217,200,0.4);">{s.label}</div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       § 001 — 5 FOUNDATIONAL PROBLEMS
       FROM: staging.grownetics.com (complete, with dollar anchors)
  ═══════════════════════════════════════════════════════════ -->
  <section class="section" style="background: var(--bg-alt);" aria-labelledby="problems-headline">
    <div class="container">

      <div class="section-ref">
        <div class="section-ref-bar" style="background: var(--terracotta);"></div>
        <span class="ref-label" style="color: var(--terracotta);">§ 001 · Five Problems Costing You Every Harvest</span>
      </div>

      <div class="grid md:grid-cols-2 gap-14 items-start mb-12">
        <div class="reveal">
          <h2 id="problems-headline" class="display-lg mb-4">
            Your growers aren't the problem.<br />
            <span style="color: var(--terracotta);">Your tools are.</span>
          </h2>
          <p class="text-ink-3 leading-relaxed mb-4">
            These aren't problems you solve by working harder. They're structural — built into how most facilities measure, control, and learn. Grownetics is built to eliminate all five.
          </p>
          <p class="text-ink-3 leading-relaxed">
            The grower isn't broken. The system is. And fixing it doesn't start with another tool. It starts with a complete one.
          </p>
        </div>
        <div class="reveal flex flex-col gap-4">
          <!-- Problem 01 -->
          <div class="card p-5" style="border-left: 3px solid var(--terracotta);">
            <div class="flex items-start gap-4">
              <div class="font-mono text-xs font-semibold shrink-0 mt-0.5" style="color: var(--gold);">01</div>
              <div>
                <h3 class="font-display font-semibold text-sm text-ink mb-1">The Measurement Gap</h3>
                <p class="text-xs text-ink-3 leading-relaxed mb-2">You have sensors. But do you have a 3D picture of every zone? Temperature at canopy isn't temperature at substrate.</p>
                <p class="text-xs font-semibold" style="color: var(--terracotta);">That's 80% of your environmental variability — and the yield loss that comes with it.</p>
              </div>
            </div>
          </div>
          <!-- Problem 02 -->
          <div class="card p-5" style="border-left: 3px solid var(--terracotta);">
            <div class="flex items-start gap-4">
              <div class="font-mono text-xs font-semibold shrink-0 mt-0.5" style="color: var(--gold);">02</div>
              <div>
                <h3 class="font-display font-semibold text-sm text-ink mb-1">The Control Precision Gap</h3>
                <p class="text-xs text-ink-3 leading-relaxed mb-2">If your climate reacts to problems, it's already too late. Thermostats chase excursions. Predictive controllers prevent them.</p>
                <p class="text-xs font-semibold" style="color: var(--terracotta);">Reactive controls waste 20–30% more energy than predictive. Every month.</p>
              </div>
            </div>
          </div>
          <!-- Problem 03 -->
          <div class="card p-5" style="border-left: 3px solid var(--terracotta);">
            <div class="flex items-start gap-4">
              <div class="font-mono text-xs font-semibold shrink-0 mt-0.5" style="color: var(--gold);">03</div>
              <div>
                <h3 class="font-display font-semibold text-sm text-ink mb-1">The Knowledge Bottleneck</h3>
                <p class="text-xs text-ink-3 leading-relaxed mb-2">Your best grower has intuition that can't be transferred. When they leave, the knowledge goes with them.</p>
                <p class="text-xs font-semibold" style="color: var(--terracotta);">One resignation costs you years of institutional knowledge and months of recovery.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Problems 04 + 05 — full width row -->
      <div class="grid md:grid-cols-2 gap-4 reveal">
        <!-- Problem 04 -->
        <div class="card p-5" style="border-left: 3px solid var(--terracotta);">
          <div class="flex items-start gap-4">
            <div class="font-mono text-xs font-semibold shrink-0 mt-0.5" style="color: var(--gold);">04</div>
            <div>
              <h3 class="font-display font-semibold text-sm text-ink mb-1">The Cycle Time Problem</h3>
              <p class="text-xs text-ink-3 leading-relaxed mb-2">Every day a plant sits in your facility is cost without revenue. Eliminating the veg phase delivers 30% less electricity, 37% less labor, 50% more harvests per year — but only if your measurement and control are precise enough.</p>
              <p class="text-xs font-semibold" style="color: var(--terracotta);">Every unnecessary day in veg is revenue you'll never recover.</p>
            </div>
          </div>
        </div>
        <!-- Problem 05 -->
        <div class="card p-5" style="border-left: 3px solid var(--terracotta);">
          <div class="flex items-start gap-4">
            <div class="font-mono text-xs font-semibold shrink-0 mt-0.5" style="color: var(--gold);">05</div>
            <div>
              <h3 class="font-display font-semibold text-sm text-ink mb-1">The Data Continuity Gap</h3>
              <p class="text-xs text-ink-3 leading-relaxed mb-2">Every harvest starts from scratch because nobody recorded what actually happened in the last one. A batch biography — every sensor reading, recipe change, and crop observation — turns cultivation into a compounding learning system.</p>
              <p class="text-xs font-semibold" style="color: var(--terracotta);">Your 50th harvest should be dramatically better than your first. Is it?</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       SECONDARY LEAD CAPTURE — after problems, before products
  ═══════════════════════════════════════════════════════════ -->
  <section class="py-10 border-y" style="background: var(--surface); border-color: var(--border-light);" aria-label="Get the guide">
    <div class="container">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="flex-1 min-w-0">
          <div class="font-mono text-xs tracking-widest uppercase mb-2" style="color: var(--gold);">Free Resource</div>
          <h3 class="font-display font-semibold text-lg text-ink mb-1">The 5 Foundational Problems in CEA</h3>
          <p class="text-sm text-ink-3 max-w-lg">Cost impact, root cause, and what changes when each one is solved. No demo required.</p>
        </div>
        <form class="flex gap-3 shrink-0 w-full md:w-auto" id="guide-form">
          <input
            type="email"
            placeholder="your@email.com"
            required
            id="guide-email"
            class="px-4 py-2.5 rounded border text-sm flex-1 md:w-60 outline-none transition-all font-body"
            style="border-color: var(--border); background: white; color: var(--ink);"
          />
          <button type="submit" class="btn btn-outline text-sm py-2.5 px-5 whitespace-nowrap">Get the Guide →</button>
        </form>
        <p id="guide-success" class="text-sm font-mono hidden" style="color: var(--green);">✓ On its way to your inbox.</p>
      </div>
    </div>
  </section>

  <script>
    document.getElementById('guide-form')?.addEventListener('submit', function(e) {
      e.preventDefault();
      const email = document.getElementById('guide-email').value;
      fetch('https://go.growneticsos.com/form/submit?formId=2', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify({ mauticform: { email, source: '5-problems-guide' } })
      }).catch(() => {});
      document.getElementById('guide-form').style.display = 'none';
      document.getElementById('guide-success').classList.remove('hidden');
    });
  </script>


  <!-- ═══════════════════════════════════════════════════════
       § 002 — THE STACK
       FROM: staging1 (ProductCard components, four layers)
  ═══════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="stack-headline">
    <div class="container">

      <div class="section-ref">
        <div class="section-ref-bar"></div>
        <span class="ref-label">§ 002 · The Grownetics Stack</span>
      </div>

      <div class="max-w-xl mb-12">
        <h2 id="stack-headline" class="display-lg mb-4">Four layers. One coherent system.</h2>
        <p class="text-lg text-ink-3 leading-relaxed">
          Built to work independently or together. Designed so every layer makes the next one more powerful.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 gap-5 reveal">
        <ProductCard
          name="CropVision"
          tagline="See."
          description="10x resolution environmental monitoring. 3D microclimate mapping. Total Crop Steering™ analytics. Your operation, finally visible."
          href="/cropvision"
          badge="Monitor"
          badgeType="green"
          stats={[
            { value: "60%", label: "Less than Argus/Priva" },
            { value: "10x", label: "Sensor resolution" },
          ]}
        />
        <ProductCard
          name="Unity"
          tagline="Control."
          description="Predictive climate, CO₂, and lighting automation. UL-certified. 20% average energy savings. Precision that compounds over time."
          href="/unity"
          badge="Automate"
          badgeType="gold"
          stats={[
            { value: "20%", label: "Avg. energy savings" },
            { value: "40%", label: "Cost reduction" },
          ]}
        />
        <ProductCard
          name="Foundation"
          tagline="Design."
          description="From greenfield to retrofit: facility design engineered for efficiency, bio-security, compliance, and precision from day one."
          href="/foundation"
          badge="Design"
          badgeType="terracotta"
        />
        <ProductCard
          name="Optima Consulting"
          tagline="Optimize."
          description="Site evaluations, cultivation support, supplier audits. Expert growers who've run commercial facilities, not consultants who've read about them."
          href="/consulting"
          badge="Consult"
          badgeType="gold"
          stats={[
            { value: "2.5–3.2", label: "lbs per light" },
          ]}
        />
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       § 003 — GROWNETICS OS TEASER (marked In Development)
  ═══════════════════════════════════════════════════════════ -->
  <section
    class="relative overflow-hidden"
    style="padding: 96px 0; background: #2B2C2E;"
    aria-labelledby="os-teaser-headline"
  >
    <div class="absolute inset-0" style="background-image: linear-gradient(rgba(154,136,96,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(154,136,96,0.04) 1px, transparent 1px); background-size: 72px 72px;"></div>
    <div class="absolute bottom-0 left-0 w-2/3 h-80 pointer-events-none" style="background: radial-gradient(ellipse at bottom left, rgba(77,180,5,0.10) 0%, transparent 70%);"></div>

    <div class="container relative z-10">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-0.5 h-3.5 rounded" style="background: rgba(154,136,96,0.5);"></div>
        <span class="font-mono text-xs tracking-widest uppercase" style="color: rgba(154,136,96,0.55);">§ 003 · What's Coming — H2 2026</span>
      </div>

      <div class="max-w-3xl">
        <div class="flex flex-wrap gap-3 mb-6">
          <span class="font-mono text-xs tracking-widest uppercase px-3 py-1.5 rounded border" style="color: rgba(77,180,5,0.85); border-color: rgba(77,180,5,0.25); background: rgba(77,180,5,0.07);">◉ In Development · Coming H2 2026</span>
        </div>

        <h2 id="os-teaser-headline" class="font-display font-semibold mb-5" style="font-size: clamp(2rem, 4.5vw, 3.25rem); color: #E9E8EE; line-height: 1.15;">
          Grownetics OS is the AI layer<br />
          <span style="color: #4DB405;">that connects it all.</span>
        </h2>

        <p class="text-base leading-relaxed mb-8 max-w-2xl" style="color: rgba(151,153,166,0.9); font-size: 1.05rem;">
          Every data point your stack collects. Every decision your team makes.
          One intelligence layer that coordinates them and gets smarter with every grow.
          Join the waitlist to be in the first cohort.
        </p>

        <a href="/os" class="btn btn-primary">Join the Waitlist. Be First →</a>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       § 004 — PROOF (multiple evidence types)
       FROM: staging.grownetics.com (case study + research + testimonials)
  ═══════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="proof-headline">
    <div class="container">

      <div class="section-ref">
        <div class="section-ref-bar"></div>
        <span class="ref-label">§ 004 · Proven at Commercial Scale</span>
      </div>

      <h2 id="proof-headline" class="display-md mb-4 reveal">Not promises. Documented results.</h2>
      <p class="text-ink-3 leading-relaxed mb-12 max-w-lg reveal">From university-affiliated research to operating farms.</p>

      <!-- Stat block -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-14 reveal">
        {[
          { value: "1M+", label: "sq ft managed", detail: "CO · CA · Canada · International" },
          { value: "40%", label: "Energy reduction", detail: "UC Boulder / Fleurish Farms study" },
          { value: "20%+", label: "HVAC efficiency", detail: "HiFEC algorithm, any HVAC system" },
          { value: "2015", label: "Founded Colorado", detail: "10+ years field-proven" },
        ].map((stat) => (
          <div class="card p-5 text-center">
            <div class="stat-number text-2xl mb-1">{stat.value}</div>
            <div class="font-display font-semibold text-sm text-ink mb-1">{stat.label}</div>
            <div class="font-mono text-xs text-ink-3 leading-snug">{stat.detail}</div>
          </div>
        ))}
      </div>

      <!-- Proof cards — case study, research, enterprise -->
      <div class="grid md:grid-cols-3 gap-5 mb-12 reveal">

        <!-- Shift Cannabis — featured -->
        <div class="card p-6 md:col-span-1" style="border-top: 3px solid var(--green); background: var(--surface-2);">
          <div class="font-mono text-xs uppercase tracking-widest mb-3" style="color: var(--gold);">Case Study · Shift Cannabis</div>
          <div class="flex items-end gap-4 mb-4">
            <div>
              <div class="stat-number" style="font-size: 2.5rem;">2</div>
              <div class="text-xs text-ink-3 font-mono uppercase tracking-wide">full-time staff</div>
            </div>
            <div class="h-px flex-1 mb-4" style="background: var(--border-light);"></div>
            <div>
              <div class="stat-number" style="font-size: 2.5rem;">30K</div>
              <div class="text-xs text-ink-3 font-mono uppercase tracking-wide">sq ft operation</div>
            </div>
          </div>
          <p class="text-xs text-ink-3 leading-relaxed italic">"Great equipment and software for CEA. Grownetics helped us build custom solutions for a more efficient work environment. Great team."</p>
          <div class="flex items-center gap-3 mt-4">
            <img src="/images/testimonial-cody.jpg" alt="Cody Monroe" class="w-9 h-9 rounded-full object-cover" onerror="this.style.display='none'" />
            <div>
              <div class="text-sm font-semibold text-ink">Cody Monroe</div>
              <div class="text-xs text-ink-3">Shift Cannabis</div>
            </div>
          </div>
        </div>

        <!-- UC Boulder energy study -->
        <div class="card p-6">
          <div class="font-mono text-xs uppercase tracking-widest mb-3" style="color: var(--gold);">University Research</div>
          <div class="stat-number mb-1" style="font-size: 3rem;">40%</div>
          <div class="font-mono text-xs text-ink-3 uppercase tracking-widest mb-3">Energy reduction</div>
          <p class="text-sm text-ink-3 leading-relaxed">Grownetics, Fleurish Farms, and University of Colorado, Boulder. 40% reduction in energy vs. sole-source LED lighting through open architecture platform integration.</p>
        </div>

        <!-- The Work Cannabis -->
        <div class="card p-6">
          <div class="font-mono text-xs uppercase tracking-widest mb-3" style="color: var(--gold);">Enterprise · R&D Facility</div>
          <p class="text-sm text-ink-3 leading-relaxed italic mb-5">"We designed our R&D facility to be at the leading edge of efficiency, technology and innovation. What we were trying to do would never have been possible without the Grownetics sensing and automation platform to tie it all together."</p>
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full flex items-center justify-center font-bold text-sm shrink-0" style="background: var(--bg-alt); color: var(--ink-2);">ES</div>
            <div>
              <div class="text-sm font-semibold text-ink">Eliyahu Scheiman</div>
              <div class="text-xs text-ink-3">The Work Cannabis</div>
            </div>
          </div>
        </div>

        <!-- Twin Peaks -->
        <div class="card p-6">
          <div class="font-mono text-xs uppercase tracking-widest mb-3" style="color: var(--gold);">Commercial · Retrofit</div>
          <p class="text-sm text-ink-3 leading-relaxed italic mb-5">"Their advice and depth of knowledge in CEA is really top notch. Their recommended upgrades have been spot on and budget friendly. We'll be implementing Grownetics' systems for all our new sites."</p>
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full flex items-center justify-center font-bold text-sm shrink-0" style="background: var(--bg-alt); color: var(--ink-2);">PQ</div>
            <div>
              <div class="text-sm font-semibold text-ink">Paul Quinn</div>
              <div class="text-xs text-ink-3">Twin Peaks Cannabis</div>
            </div>
          </div>
        </div>

        <!-- Sacramento greenhouse -->
        <div class="card p-6">
          <div class="font-mono text-xs uppercase tracking-widest mb-3" style="color: var(--gold);">Scale · Greenhouse</div>
          <div class="stat-number mb-1" style="font-size: 2.75rem;">250K</div>
          <div class="font-mono text-xs text-ink-3 uppercase tracking-widest mb-3">Sq ft, fully automated</div>
          <p class="text-sm text-ink-3 leading-relaxed">Sacramento greenhouse. Crop analytics and AI tools deployed across one of the largest automated CEA facilities in the country.</p>
        </div>

        <!-- San Diego / HiFEC energy -->
        <div class="card p-6">
          <div class="font-mono text-xs uppercase tracking-widest mb-3" style="color: var(--gold);">Controls · Energy</div>
          <div class="stat-number mb-1" style="font-size: 2.75rem;">~30%</div>
          <div class="font-mono text-xs text-ink-3 uppercase tracking-widest mb-3">Energy reduction</div>
          <p class="text-sm text-ink-3 leading-relaxed">San Diego commercial greenhouse. HiFEC predictive algorithm deployed on existing HVAC infrastructure — no equipment replacement required.</p>
        </div>

      </div>

      <!-- Customer logo bar — FROM staging.grownetics.com -->
      <div class="reveal">
        <p class="font-mono text-xs text-ink-3 uppercase tracking-widest mb-6">Deployed across commercial facilities</p>
        <div class="flex flex-wrap items-center gap-x-10 gap-y-3 opacity-60">
          {['Shift Cannabis', 'The Work Cannabis', 'Twin Peaks Cannabis', 'Dalwhinnie Farms', 'Fleurish Farms', 'Green Horizons', 'House of Cultivars'].map(name => (
            <span class="font-display font-semibold text-base text-ink-3">{name}</span>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       § 005 — HOW WE WORK
       FROM: staging.grownetics.com (4-step process, renamed step 1)
  ═══════════════════════════════════════════════════════════ -->
  <section class="section" style="background: var(--bg-alt);" aria-labelledby="how-headline">
    <div class="container">

      <div class="section-ref">
        <div class="section-ref-bar"></div>
        <span class="ref-label">§ 005 · How We Work</span>
      </div>

      <div class="grid md:grid-cols-2 gap-14 items-start">
        <div class="reveal">
          <h2 id="how-headline" class="display-lg mb-5">We start with your facility. Not a product pitch.</h2>
